# Configuratie backend QualiTrace
# Copiaza acest fisier ca .env in folderul backend/ si ajusteaza valorile

# Portul pe care ruleaza backend-ul
PORT=3001

# Cheia secreta JWT - SCHIMBA aceasta valoare cu ceva unic si lung!
JWT_SECRET=qualitrace-secret-change-this-in-production-xyz123

# Mediu
NODE_ENV=production
